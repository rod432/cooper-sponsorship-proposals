# Supabase project credentials.
# Get these from your Supabase project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=
# Either the new publishable key (sb_publishable_...) or the legacy anon JWT.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Resend (optional). When set, Send-to-Player sends server-side.
# Otherwise the dialog opens the staff member's mail client with the
# message pre-filled.
RESEND_API_KEY=
RESEND_FROM_ADDRESS="Cooper Cricket <proposals@coopercricket.com.au>"

# Optional: override the base URL embedded in player approval links.
# Auto-detected from the request when unset.
NEXT_PUBLIC_SITE_URL=
